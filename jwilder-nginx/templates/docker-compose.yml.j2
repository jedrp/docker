version: '3.5'

services:
  public-nginx:
    container_name: public-nginx
    image: jwilder/nginx-proxy:1.6
    restart: always
    network_mode: host
    environment:
      LOG_FORMAT: $$remote_addr - $$remote_user [$$time_local] "$$request" $$status $$body_bytes_sent "$$http_referer" "$$http_user_agent" "$$http_x_forwarded_for" request_time=$$request_time upstream_response_time=$$upstream_response_time upstream_connect_time=$$upstream_connect_time upstream_header_time=$$upstream_header_time
    volumes:
      - /var/run/docker.sock:/tmp/docker.sock:ro
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"